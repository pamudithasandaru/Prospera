{
  "name": "prospera-agriculture-platform",
  "version": "1.0.0",
  "description": "Comprehensive Agriculture Management & Marketplace Platform",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "set PORT=3001 & cd client & npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "seed": "node server/seed.js",
    "setup:firebase": "node scripts/setup-firebase.js",
    "test:firebase": "node scripts/test-firestore-connection.js"
  },
  "keywords": [
    "agriculture",
    "farming",
    "marketplace",
    "ai",
    "social-network"
  ],
  "author": "Prospera Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^13.6.1",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "4.1",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "socket.io": "^4.6.0",
    "stripe": "^14.9.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "baseline-browser-mapping": "^2.9.19",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
